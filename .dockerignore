frontend/.cache

# 本地部署辅助文件
uploads
result_*.json
# 只排根目录的 package-lock.json，保留 frontend/package-lock.json（npm install --frozen 需要）
/package-lock.json

# 项目自身的 docker 工件
*.tar
*.tar.gz
